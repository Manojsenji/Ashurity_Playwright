{
  "name": "playwright-enterprise-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:qa": "cross-env ENV=QA playwright test",
    "test:qa:headed": "cross-env ENV=QA playwright test --headed",
    "test:qa:debug": "cross-env ENV=QA playwright test --debug",
    "test:dev": "cross-env ENV=DEV playwright test",
    "test:dev:headed": "cross-env ENV=DEV playwright test --headed",
    "test:dev:debug": "cross-env ENV=DEV playwright test --debug",
    "test:preprod": "cross-env ENV=PREPROD playwright test",
    "test:preprod:headed": "cross-env ENV=PREPROD playwright test --headed",
    "test:preprod:debug": "cross-env ENV=PREPROD playwright test --debug",

    "allure:clean": "rimraf allure-results allure-report",
    "allure:history": "node scripts/copyHistory.js",
    "posttest": "ts-node utils/allureEnvironment.ts",
    "allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report",

    "test:dev:allure": "npm run allure:clean && cross-env ENV=DEV playwright test",
    "test:qa:allure": "npm run allure:clean && cross-env ENV=QA playwright test && npm run allure:generate && npm run allure:open",
    "test:preprod:allure": "npm run allure:clean && cross-env ENV=PREPROD playwright test && npm run allure:generate && npm run allure:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.2",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.5.0",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "winston": "^3.19.0"
  }
}
